{
    "layer": "top",
    "position": "top",
    "height": 40,
    "spacing": 0,
    "exclusive": true,

    "modules-left": [
        "hyprland/workspaces",
        "hyprland/window"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "cpu",
        "memory",
        "battery",
        "network",
        "custom/separator",
        "pulseaudio",
        "bluetooth",
        "tray"
    ],

    "hyprland/workspaces": {
        "format": "{name}",
        "disable-scroll": true,
        "all-outputs": true,
        "active-only": false,
        "on-click": "activate"
    },

    "hyprland/window": {
        "format": "  {class}",
        "max-length": 50,
        "rewrite": {
            "kitty": "TERM",
            "firefox": "WEB BROWSER",
            "": "DESKTOP"
        }
    },

    "clock": {
        "format": "<span color='#888888'>{:%a}</span> {:%I:%M} <span color='#888888'>{:%p}</span>",
        "tooltip": false
    },

    "cpu": {
        "format": "<span color='#888888'></span> {usage}%",
        "interval": 2
    },

    "memory": {
        "format": "<span color='#888888'></span> {used:0.1f}G",
        "interval": 2
    },

    "battery": {
        "format": "<span color='#888888'></span> {capacity}%",
        "format-charging": "<span color='#888888'></span> {capacity}%",
        "format-plugged": "<span color='#888888'></span> {capacity}%"
    },

    "network": {
        "format-wifi": "<span color='#888888'></span> {essid}",
        "format-ethernet": "<span color='#888888'></span> WIRED",
        "format-disconnected": "<span color='#888888'>⚠</span> OFFLINE",
        "tooltip": false
    },

    "custom/separator": {
        "format": "|",
        "tooltip": false
    },

    "pulseaudio": {
        "format": "<span color='#888888'></span>",
        "format-muted": "<span color='#888888'></span>",
        "on-click": "pavucontrol",
        "tooltip": false
    },

    "bluetooth": {
        "format": "<span color='#888888'></span>",
        "format-disabled": "<span color='#888888'></span>",
        "tooltip": false
    },

    "tray": {
        "icon-size": 14,
        "spacing": 15
    }
}